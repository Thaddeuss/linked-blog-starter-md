
"smart_sources:_000.General/The Paradox of Behavior Change.md": {"path":"_000.General/The Paradox of Behavior Change.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"zbcz2s","at":1772113914315},"class_name":"SmartSource","last_import":{"mtime":1760197808000,"size":1027,"at":1772113914316,"hash":"zbcz2s"},"blocks":{"#":[1,6],"##{1}":[2,2],"##{2}":[3,3],"##{3}":[4,4],"##{4}":[5,6],"##Natural tendency of life is to find a balance. Any effort for rapid growth will meet these forces. Once the balance is lost the system is motivated to  bring it back to normal.":[7,14],"##Natural tendency of life is to find a balance. Any effort for rapid growth will meet these forces. Once the balance is lost the system is motivated to  bring it back to normal.#{1}":[9,10],"##Natural tendency of life is to find a balance. Any effort for rapid growth will meet these forces. Once the balance is lost the system is motivated to  bring it back to normal.#{2}":[11,14],"##The weight to small, muscle atrophy. The weight too heavy, you'll injure yourself. Weight just a bit above your normal, muscle will adapt and get stronger. And the Equilibrium will take small step forward.":[15,19]},"outlinks":[{"title":"James Clear","target":"James Clear","line":2},{"title":"Compound Interest","target":"Compound Interest","line":4},{"title":"Equilibrium","target":"Equilibrium","line":4},{"title":"Homeostasis","target":"Homeostasis","line":4},{"title":"MOC Habits","target":"MOC Habits","line":4},{"title":"Practice; Mastery","target":"Practice; Mastery","line":4},{"title":"George Leonard","target":"George Leonard","line":12}],"metadata":{"tags":["#articles"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
