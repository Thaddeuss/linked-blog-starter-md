
"smart_sources:_007.Books/Extreme Ownership/Extreme Ownership 📕.md": {"path":"_007.Books/Extreme Ownership/Extreme Ownership 📕.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"1xx547i","at":1772113914943},"class_name":"SmartSource","last_import":{"mtime":1673475776000,"size":1833,"at":1772113914945,"hash":"1xx547i"},"blocks":{"#Extreme Ownership":[1,8],"#Extreme Ownership#{1}":[3,4],"#Extreme Ownership#{2}":[5,5],"#Extreme Ownership#{3}":[6,6],"#Extreme Ownership#{4}":[7,7],"#Extreme Ownership#{5}":[8,8],"#Highlights":[9,30],"#Highlights####[[If substandard performance is accepted and no one is held accountable—if there are no consequences—that poor performance becomes the new standard. Therefore, leaders must enforce standards.]]":[10,11],"#Highlights####[[Not knowing the \"why\" prohibits you from believing in the mission. When you are in a leadership position, that is a recipe for failure, and it is unacceptable. As a leader, you must believe.”]]":[12,13],"#Highlights####[[Cover and Move means teamwork. All elements within the greater team are crucial and must work together to accomplish the mission, mutually supporting one another for that singular purpose.]]":[14,15],"#Highlights####[[Simplifying as much as possible is crucial to success.]]":[16,17],"#Highlights####[[Everyone that is part of the mission must know and understand his or her role in the mission and what to do in the event of likely contingencies.]]":[18,19],"#Highlights####[[When overwhelmed, fall back upon this principle Prioritize and Execute.]]":[20,21],"#Highlights####[[Leaders must be free to move to where they are most needed]]":[22,23],"#Highlights####[[Take responsibility for leading everyone in your world, subordinates and superiors alike.  If someone isn’t doing what you want or need them to do, look in the mirror first and determine what you can do to better enable this.]]":[24,25],"#Highlights####[[The moment the alarm goes off is the first test; it sets the tone for the rest of the day. The test is not a complex one when the alarm goes off, do you get up out of bed, or do you lie there in comfort and fall back to sleep?]] ^651a36":[26,27],"#Highlights####[[Analyze the mission.]]":[28,29],"#Highlights####[[Don’t ask your leader what you should do, tell them what you are going to do.]]":[30,30]},"outlinks":[{"title":"rw-book-cover","target":"https://img1.od-cdn.com/ImageType-100/2390-1/{6F40D15A-BDAF-43B0-B3C8-C0AA9A1CAF4A}Img100.jpg","line":3,"embedded":true},{"title":"Jocko Willink","target":"Jocko Willink","line":5},{"title":"If substandard performance is accepted and no one is held accountable—if there are no consequences—that poor performance becomes the new standard. Therefore, leaders must enforce standards.","target":"If substandard performance is accepted and no one is held accountable—if there are no consequences—that poor performance becomes the new standard. Therefore, leaders must enforce standards.","line":10},{"title":"Not knowing the \"why\" prohibits you from believing in the mission. When you are in a leadership position, that is a recipe for failure, and it is unacceptable. As a leader, you must believe.”","target":"Not knowing the \"why\" prohibits you from believing in the mission. When you are in a leadership position, that is a recipe for failure, and it is unacceptable. As a leader, you must believe.”","line":12},{"title":"Cover and Move means teamwork. All elements within the greater team are crucial and must work together to accomplish the mission, mutually supporting one another for that singular purpose.","target":"Cover and Move means teamwork. All elements within the greater team are crucial and must work together to accomplish the mission, mutually supporting one another for that singular purpose.","line":14},{"title":"Simplifying as much as possible is crucial to success.","target":"Simplifying as much as possible is crucial to success.","line":16},{"title":"Everyone that is part of the mission must know and understand his or her role in the mission and what to do in the event of likely contingencies.","target":"Everyone that is part of the mission must know and understand his or her role in the mission and what to do in the event of likely contingencies.","line":18},{"title":"When overwhelmed, fall back upon this principle Prioritize and Execute.","target":"When overwhelmed, fall back upon this principle Prioritize and Execute.","line":20},{"title":"Leaders must be free to move to where they are most needed","target":"Leaders must be free to move to where they are most needed","line":22},{"title":"Take responsibility for leading everyone in your world, subordinates and superiors alike.  If someone isn’t doing what you want or need them to do, look in the mirror first and determine what you can do to better enable this.","target":"Take responsibility for leading everyone in your world, subordinates and superiors alike.  If someone isn’t doing what you want or need them to do, look in the mirror first and determine what you can do to better enable this.","line":24},{"title":"The moment the alarm goes off is the first test; it sets the tone for the rest of the day. The test is not a complex one when the alarm goes off, do you get up out of bed, or do you lie there in comfort and fall back to sleep?","target":"The moment the alarm goes off is the first test; it sets the tone for the rest of the day. The test is not a complex one when the alarm goes off, do you get up out of bed, or do you lie there in comfort and fall back to sleep?","line":26},{"title":"Analyze the mission.","target":"Analyze the mission.","line":28},{"title":"Don’t ask your leader what you should do, tell them what you are going to do.","target":"Don’t ask your leader what you should do, tell them what you are going to do.","line":30}],"metadata":{"tags":["#books"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
