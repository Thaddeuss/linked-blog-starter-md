12,0.03185032,-0.01841982,-0.0649812,-0.01722572,-0.01763716,0.02936865,0.02420384,-0.01741276,0.00598676,0.05373043,-0.04473935,-0.03330863,0.04602044,-0.0237385,0.0199029,-0.06809574,-0.02695811,-0.028868,0.02967206,0.042518,0.04612565,0.01045816,-0.02499632,0.08742324,0.00369176,-0.01981467,0.01566921,0.04013539,-0.05899882,0.03211308,0.03612403,0.00443775,-0.01143676,0.03963267,0.03761631,0.04764597,0.01259911,-0.04286799,-0.00256398,0.07913779,-0.10534872,0.08978453,0.02717524,-0.0030439,0.0040044,-0.0608703,-0.05729416,0.0016899,-0.01732758,-0.00872946,0.00776212,-0.01908897,-0.02325755,0.04449356,-0.01483784,-0.25261492,-0.0525399,-0.04286558,0.05593947,-0.09244021,0.0532215,0.0653017,0.04881061,-0.14886102,0.01837432,0.02183568,0.01621722,0.03014414,-0.00442837,-0.0029783,0.00270613,0.03507654,0.02297437,-0.00554023,-0.02105351,0.04946123,0.01968289,0.15636407,-0.02278749,0.06243153,-0.01403974,0.04237818,0.04597917,0.04835087,-0.01041602,-0.03872425,0.04163971,-0.01492949,-0.00620372,0.02337698,-0.03440153,0.02628829,-0.016831,0.02309465,-0.03101096,0.00878318,0.02153663,0.05148518,0.00358573,0.11504293,-0.04083325,-0.01649516,-0.0596073,0.02673954,-0.02539377,-0.05150473,0.01564261,0.00385271,0.04714618,-0.0216432,0.02649677,-0.03037399,0.03377058,-0.0491214,0.00339001,0.00064164,0.00677904,0.02334992,0.11145612,-0.00033268],"last_embed":{"hash":"wbq6ss","tokens":478}}},"text":null,"length":0,"last_read":{"hash":"wbq6ss","at":1772114197337},"key":"_007.Books/Real Marriage/Real Marriage 📕.md#Real Marriage","lines":[1,64],"size":2662,"outlinks":[{"title":"rw-book-cover","target":"https://readwise-assets.s3.amazonaws.com/media/uploaded_book_covers/profile_40775/e26dd71b-6690-4528-9b16-7fd32c3c40b4.jpg","line":3,"embedded":true},{"title":"Mark Driscoll","target":"Mark Driscoll","line":6},{"title":"Marriage; Relationships","target":"Marriage; Relationships","line":8},{"title":"Martin Luther King and His wife Katie","target":"Martin Luther King and His wife Katie","line":10},{"title":"Marriage is about friendship.","target":"Marriage is about friendship.","line":12},{"title":"Fruitfulness of Wife and Husban serving God together.","target":"Fruitfulness of Wife and Husban serving God together.","line":14},{"title":"Action before feeling - Action promotes feelings","target":"Action before feeling - Action promotes feelings","line":16},{"title":"Create habits of doing things together","target":"Create habits of doing things together","line":18},{"title":"Importance of being emotionally avalible for your wife. Avoid the problem solving mode. She doesnt need to be \"figured out\".","target":"Importance of being emotionally avalible for your wife. Avoid the problem solving mode. She doesnt need to be \"figured out\".","line":20},{"title":"Couples who pray and play together stay together.","target":"Couples who pray and play together stay together.","line":22},{"title":"“What if God designed marriage to make us holy more than to make us happy”25 (Location 870)","target":"“What if God designed marriage to make us holy more than to make us happy”25 (Location 870)","line":24},{"title":"Being the responsible head does not mean that a man does everything in the family, but rather that everything gets done.","target":"Being the responsible head does not mean that a man does everything in the family, but rather that everything gets done.","line":26},{"title":"Disagreement - first agree you are both on the same team and work towards same goal. Choice either to drift apart or get closer to each other.","target":"Disagreement - first agree you are both on the same team and work towards same goal. Choice either to drift apart or get closer to each other.","line":28},{"title":"Everything, for a man, is viewed as respect or disrespect. For a woman, everything is seen as loving or unloving.","target":"Everything, for a man, is viewed as respect or disrespect. For a woman, everything is seen as loving or unloving.","line":30},{"title":"A wife flourishes with a loving husband, and a husband becomes courageous with a respectful wife.","target":"A wife flourishes with a loving husband, and a husband becomes courageous with a respectful wife.","line":32},{"title":"Our value comes not from what we do; rather, what we do comes from our value as God’s image bearers. (Location 1669)","target":"Our value comes not from what we do; rather, what we do comes from our value as God’s image bearers. (Location 1669)","line":34},{"title":"Our marriages only seem “unfixable” if we are unwilling to repent.","target":"Our marriages only seem “unfixable” if we are unwilling to repent.","line":36},{"title":"4 Horseman of broken marriage - Criticism, Contempt, Defensiveness, Stonewalling","target":"4 Horseman of broken marriage - Criticism, Contempt, Defensiveness, Stonewalling","line":38},{"title":"“Couples don’t fall out of love so much as they fall out of repentance.”","target":"“Couples don’t fall out of love so much as they fall out of repentance.”","line":40},{"title":"The only alternative to forgiveness is bitterness. And the only alternative to bitterness is forgiveness.","target":"The only alternative to forgiveness is bitterness. And the only alternative to bitterness is forgiveness.","line":42},{"title":"Marriage either gets bitter or gets better.","target":"Marriage either gets bitter or gets better.","line":44},{"title":"When we are sinned against, we need to forgive quickly.","target":"When we are sinned against, we need to forgive quickly.","line":46},{"title":"Love is more like a song than a math equation. It requires a sense of poetry and passion to be any good at it.","target":"Love is more like a song than a math equation. It requires a sense of poetry and passion to be any good at it.","line":48},{"title":"Our family television is also in the most visible area of the home in an effort to help us monitor what our children watch.","target":"Our family television is also in the most visible area of the home in an effort to help us monitor what our children watch.","line":50},{"title":"If we do not choose humility, God will choose humiliation for us. So we must willfully, earnestly, and continually humble ourselves.","target":"If we do not choose humility, God will choose humiliation for us. So we must willfully, earnestly, and continually humble ourselves.","line":52},{"title":"It takes between nine and fourteen years for a couple to become not entirely unselfish, but rather less selfish, and begin to shift from “me” to “we.”","target":"It takes between nine and fourteen years for a couple to become not entirely unselfish, but rather less selfish, and begin to shift from “me” to “we.”","line":54},{"title":"Sex","target":"Sex","line":56},{"title":"Planning in family","target":"Planning in family","line":58},{"title":"Everyone has something to teach you if you are humble enough to learn.","target":"Everyone has something to teach you if you are humble enough to learn.","line":60},{"title":"Your spouse is the most sanctifying, and often most frustrating, relationship you will have.","target":"Your spouse is the most sanctifying, and often most frustrating, relationship you will have.","line":62},{"title":"“GETTING TO KNOW YOUR SPOUSE” QUESTIONNAIRE","target":"“GETTING TO KNOW YOUR SPOUSE” QUESTIONNAIRE","line":64}],"class_name":"SmartBlock","last_embed":{"hash":"wbq6ss","at":1772114197337}},
