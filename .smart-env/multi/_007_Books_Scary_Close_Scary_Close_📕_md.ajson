"smart_blocks:_007.Books/Scary Close/Scary Close 📕.md#Scary Close#Highlights####[[God doesn’t give us crying, pooping children because he wants to advance our careers. He gives them to us to create chaos and deter us from investing too much energy in the gluttonous idols of self-absorption.| God doesn’t give us crying, pooping children because he wants to advance our careers. He gives them to us for the same reason he confused language at the Tower of Babel, to create chaos and deter us from investing too much energy in the gluttonous idols of self-absorption.]] ^c09bda": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.01671273,0.01766095,0.0013604,-0.03444873,-0.01789712,0.00549749,0.03087422,0.01205049,0.06598554,-0.07502857,0.00338178,-0.09167106,0.04622868,0.01202022,0.01242162,0.00189541,-0.04035596,0.02640724,-0.16827749,0.03082234,0.12146619,-0.0242263,0.05138396,-0.05712346,0.03896828,-0.00219029,0.0023283,-0.04148195,-0.03127309,-0.18516606,0.03590053,-0.01440892,-0.01857042,-0.02108859,0.01509545,0.00807196,-0.04079886,0.04118974,-0.0072679,0.07548466,0.05448841,0.06543725,-0.06105252,0.00555067,0.02235723,-0.00600385,-0.05017724,-0.02492529,0.00299251,-0.0245766,-0.08467267,0.00068789,-0.04230966,0.03533473,-0.03998919,-0.00650596,0.06100157,0.00655843,0.03023098,0.03756652,0.05563185,0.0309063,-0.15658514,0.06549885,0.01710375,-0.02227506,-0.00820872,0.00684367,0.05193655,0.04381134,-0.01156811,0.0033362,-0.00666473,0.01549845,0.00587816,-0.00954777,0.01241383,-0.05315182,0.00545383,-0.01178326,-0.01962454,0.01770323,-0.0302465,-0.02936953,-0.06470805,-0.0069643,0.04200942,-0.05125923,0.01923775,0.0436365,-0.00311276,-0.03083047,0.05292315,0.0178404,-0.04953377,-0.01589323,-0.01090529,0.00073341,-0.15394673,0.10896949,-0.02919863,0.01731174,0.00568109,-0.00819517,0.06394942,0.03021254,0.02198099,-0.04002337,-0.06241265,0.0136276,0.0027097,-0.0346843,0.00362976,-0.11536172,0.07783315,0.00439938,0.06890275,-0.00249914,-0.03008718,-0.00767654,0